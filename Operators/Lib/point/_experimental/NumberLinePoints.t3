    {
      "Id": "6a6052ad-01aa-47af-9028-a0352833813f"/*CustomPointShader*/,
      "SymbolId": "3d958f08-9c0f-45eb-a252-de880b5834f3",
      "InputValues": [
        {
          "Id": "864dfe5a-14f2-490f-be9c-ee13ad58605c"/*AdditionalDefines*/,
          "Type": "System.String",
          "Value": "StructuredBuffer<int2> Indices : register(t3);"
        },
        {
          "Id": "e9712b03-e7aa-4fe5-b5cf-f2c5d0c0b0df"/*ShaderCode*/,
          "Type": "System.String",
          "Value": "// Initialize point buffer with normalized digit size\n\nuint maxPointsPerChar = (uint)A;\nuint charCount = (uint)B;\n\nuint charIndex = idx;\n\nif(charIndex > charCount) \n  return;\n\nuint srcIndex= (uint)Indices[charIndex].x;\nuint pointsInChar = (uint)Indices[charIndex].y;\n\nfloat updateMarker =  C%0.01;\n\nuint charResultStart = charIndex * maxPointsPerChar;\n\nfor(uint i = 0; i< pointsInChar; i++) \n{\n  ResultPoints[charResultStart + i] = SourcePoints[srcIndex + i];\n  //ResultPoints[charResultStart + i].FX1 = i + updateMarker;\n} \n \n\nfor(; i< maxPointsPerChar; i++) \n{\n  ResultPoints[charResultStart + i].Position = 0;\n  ResultPoints[charResultStart + i].Scale = NAN;\n  ResultPoints[charResultStart + i].Rotation.x = NAN;\n  //ResultPoints[charResultStart + i].FX1 = 666 + updateMarker;\n}\n\nreturn; // Don't write P in template;\n\n\n"
        }
      ],
      "Outputs": []
    },
