    {
      "Id": "7dbeb39a-8075-4766-894a-99bbbe4b5d3f"/*CustomPointShader*/,
      "SymbolId": "3d958f08-9c0f-45eb-a252-de880b5834f3",
      "InputValues": [
        {
          "Id": "864dfe5a-14f2-490f-be9c-ee13ad58605c"/*AdditionalDefines*/,
          "Type": "System.String",
          "Value": "cbuffer TransformsCam1 : register(b3)\n{\n    float4x4 CameraToClipSpace;\n    float4x4 ClipSpaceToCamera;\n    float4x4 WorldToCamera;\n    float4x4 CameraToWorld;\n    float4x4 WorldToClipSpace;\n    float4x4 ClipSpaceToWorld;\n    float4x4 ObjectToWorld;\n    float4x4 WorldToObject;\n    float4x4 ObjectToCamera;\n    float4x4 ObjectToClipSpace;\n};\n"
        },
        {
          "Id": "a5c7863e-9c26-4109-9851-3244086b0ccc"/*A*/,
          "Type": "System.Single",
          "Value": 1.7
        },
        {
          "Id": "e9712b03-e7aa-4fe5-b5cf-f2c5d0c0b0df"/*ShaderCode*/,
          "Type": "System.String",
          "Value": "p=SourcePoints[idx/3];\n//p.Rotation=float4(0,0,0,1);\nuint ii=idx%3;\n\n// Position\nif(A<0.5) { \n  p.FX2=p.Position[ii]; \n}\nelse if(A < 1.5) {  \n  p.FX2=p.Color[ii]; \n}\nelse\n{\n  if(ii==0) p.FX2=p.FX1;\n  if(ii==1) p.FX2=p.FX2;\n  if(ii==2) p.FX2= NAN;\n}\n\n\nfloat3 up=mul(float3(0,1,0),(float3x3)CameraToWorld);\nfloat3 dir=normalize(p.Position-CameraToWorld[3].xyz);\n\n//p.Rotation=qLookAt(dir,up);\n\nif(C>0.5) p.Rotation = qFromMatrix3((float3x3)WorldToCamera);\n\nfloat3 down = qRotateVec3(float3(0,1,0), p.Rotation);\n\np.Position+=-float(ii) * down * 0.08 * B * p.Scale.y;\np.Position += qRotateVec3( Offset * B, p.Rotation);\n"
        }
      ],
      "Outputs": []
    },
    {
      "Id": "8cb47de9-b4d6-4bc8-ac92-bd0c8e18ee78"/*MultiplyInt*/,
      "SymbolId": "6a4edb6a-5ced-4356-9090-4bf770cdeb52",
      "InputValues": [
        {
          "Id": "e02f9e84-a7bf-45bf-9cb1-0b0c1c396796"/*B*/,
          "Type": "System.Int32",
          "Value": 3
        }
      ],
      "Outputs": []
    },
    {
