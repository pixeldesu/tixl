                  "Id": "ea6bdcae-9137-4a1f-b18d-e36bf1a843a1",
                  "NormalizedPosition": 0.93555003,
                  "Color": {
                    "R": 1.0,
                    "G": 0.16091663,
                    "B": 0.5806323,
                    "A": 1.0
                  }
                }
              ]
            }
          },
          "0957ec56-8c74-4e72-aee3-c14abddcc655": "// SDF -> simple gradient\n// A: Range\n// B: FallOff\n// C: Displace\n// D: Noise\n\nfloat3 pCenter = (v1.Position + v2.Position + v3.Position)/3 \n                 + Offset;\n\nfloat3 fn= GetFieldNormal(pCenter);\n\nfloat f= GetField(float4(pCenter,1)).w;\n\nfloat vn = (v1.Normal + v2.Normal + v3.Normal)/3;\n\nf= Biased(1-(f-A)/B);\n\nfloat4 c = SampleGradient(f);\nv1.ColorRGB = c.rgb;\nv2.ColorRGB = c.rgb;\nv3.ColorRGB = c.rgb;\n\nfloat noise = hash11u(faceIndex) * D;\n\nfloat3 d = (vn ) * C * noise * f;\n\nv1.Position +=  d;\nv2.Position +=  d;\nv3.Position +=  d;\n\n"
        }
      }
    },
    {
      "Id": "3c58cb6a-2b94-4780-b6f2-f09c64865fa6",
      "IsPreset": true,
      "ActivationIndex": 6,
      "Title": "SDF -> Displace with Rotation",
      "PosOnCanvas": {
        "X": 326.0,
        "Y": 122.55056
      },
      "ParameterSetsForChildIds": {
        "00000000-0000-0000-0000-000000000000": {
          "e7f9c927-5d70-40d2-b5e3-43bd06731bf7": {
            "X": 0.94,
            "Y": 2.1,
            "Z": 0.0
          },
          "cb9f9b0e-0486-400e-9fa1-5d2a997bb7d6": -0.3,
          "ee09aa68-6191-494f-9900-f0dff16df27d": 0.15,
          "043ef621-40fb-49dd-895b-ea8226d42d20": 0.09,
          "6643b344-a69d-4142-85a6-f7c642a1e93a": 0.23,
          "d23cbda2-0ac6-40ec-8600-590b1c50e0bd": {
            "X": 0.23000002,
            "Y": 0.43
          },
          "c79b7cd6-ca23-4e3b-8eb7-3468e157f592": {
            "Gradient": {
              "Interpolation": "Linear",
              "Steps": [
                {
                  "Id": "5ccd1747-3b91-47f9-ab51-188ee069c8d2",
                  "NormalizedPosition": 0.0,
                  "Color": {
                    "R": 0.99999,
                    "G": 0.99999684,
                    "B": 1.0,
                    "A": 1.0
                  }
                },
                {
                  "Id": "29e39a3c-c75c-4425-8ad0-88d3eb50a50a",
                  "NormalizedPosition": 1.0,
                  "Color": {
                    "R": 1.0,
                    "G": 0.16091663,
                    "B": 0.5806323,
                    "A": 1.0
                  }
                }
              ]
            }
          },
          "0957ec56-8c74-4e72-aee3-c14abddcc655": "// SDF -> simple gradient\n// A: Range\n// B: FallOff\n// C: Displace\n// D: Noise\n// Offset: RandomSpin\n\nfloat3 pCenter = (v1.Position + v2.Position + v3.Position)/3 ;\n\nfloat3 fn= GetFieldNormal(pCenter);\nfloat f= GetField(float4(pCenter,1)).w;\nfloat vn = (v1.Normal + v2.Normal + v3.Normal)/3;\n\nfloat noise = hash11u(faceIndex) * D;\n\nf= 1-(f-A)/B;\nf *=  C * (noise+1);\nf = Biased(f); \n\nfloat4 rot = qFromEuler(Offset.x *f / TAU, Offset.y *f / TAU, Offset.z*f / TAU);\nfloat3 p1InF = qRotateVec3(pos1 - pCenter, rot);\nfloat3 p2InF = qRotateVec3(pos2 - pCenter, rot);\nfloat3 p3InF = qRotateVec3(pos3 - pCenter, rot);\n\n\nfloat4 c = SampleGradient(f);\nv1.ColorRGB = c.rgb;\nv2.ColorRGB = c.rgb;\nv3.ColorRGB = c.rgb;\n\nfloat3 d = (vn + fn) * f;\npCenter += d;\n\nv1.Position =  pCenter + p1InF;\nv2.Position =  pCenter + p2InF;\nv3.Position =  pCenter + p3InF;\n\n"
        }
      }
    }
  ]
