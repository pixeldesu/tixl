                  }
                },
                {
                  "Id": "fd3d0297-5cb8-499e-b9e3-81cad483740a",
                  "NormalizedPosition": 1.0,
                  "Color": {
                    "R": 1.0,
                    "G": 0.0,
                    "B": 0.36987686,
                    "A": 1.0
                  }
                }
              ]
            }
          },
          "0957ec56-8c74-4e72-aee3-c14abddcc655": "// SDF -> simple gradient\n// A: Range\n// B: FallOff\n\nfloat3 pCenter = (v1.Position + v2.Position + v3.Position)/3;\n\nfloat f= GetField(float4(pCenter,1)).w;\nf= smoothstep(1,0, (f-A)/B);\n\nfloat4 c = SampleGradient(f);\nv1.ColorRGB = c.rgb;\nv2.ColorRGB = c.rgb;\nv3.ColorRGB = c.rgb;\n\n"
        }
      }
    },
