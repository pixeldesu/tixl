          "0957ec56-8c74-4e72-aee3-c14abddcc655": "//int3 faceIndicies\n//PbrVertex v1,v2,v3\n//float4 noise= hash41u(faceIndices.x);\n\nfloat3 avgPos = (v1.Position + v2.Position + v3.Position)/3;\nfloat4 color = Gradient.SampleLevel(ClampedSampler, (avgPos.y + Offset) * A +B, 0);\n\nv1.ColorRGB = color.rgb;\nv2.ColorRGB = color.rgb;\nv3.ColorRGB = color.rgb;\n\nv1.Position += (hash41u(faceIndices.x)-0.5) * C;\nv2.Position += (hash41u(faceIndices.y)-0.5) * C;\nv3.Position += (hash41u(faceIndices.z)-0.5) * C;\n"
